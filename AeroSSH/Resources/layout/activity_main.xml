<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <!-- Connection Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/card_background"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/connection_settings"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/hostEdit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/host_hint"
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:background="@drawable/edit_text_background"
                android:padding="8dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/portEdit"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:hint="@string/port_hint"
                android:inputType="number"
                android:text="22"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:background="@drawable/edit_text_background"
                android:padding="8dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/userEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/user_hint"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/edit_text_background"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/passEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/pass_hint"
            android:inputType="textPassword"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/edit_text_background"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/serverSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@color/background" />

        <Button
            android:id="@+id/saveServerBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_server"
            android:backgroundTint="@color/button_secondary"
            android:textColor="@color/button_text" />
    </LinearLayout>

    <!-- Connection Control Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/connectBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/connect"
            android:backgroundTint="@color/button_success"
            android:textColor="@color/button_text"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/disconnectBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/disconnect"
            android:backgroundTint="@color/button_danger"
            android:textColor="@color/button_text"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/reconnectBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reconnect"
            android:backgroundTint="@color/button_primary"
            android:textColor="@color/button_text"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Status Display -->
    <TextView
        android:id="@+id/statusView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/status_disconnected"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/status_disconnected"
        android:padding="8dp"
        android:background="@color/card_background"
        android:layout_marginBottom="12dp" />

    <!-- Command Execution Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/card_background"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/command_section"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/commandEdit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/command_hint"
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:background="@drawable/edit_text_background"
                android:padding="8dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/runBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/run"
                android:backgroundTint="@color/button_primary"
                android:textColor="@color/button_text"
                android:padding="4dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <Spinner
            android:id="@+id/historySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/openShellBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/open_shell"
                android:backgroundTint="@color/button_primary"
                android:textColor="@color/button_text"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/sendShellBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/send_shell"
                android:backgroundTint="@color/button_primary"
                android:textColor="@color/button_text"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Log Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/card_background"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/log_section"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/logView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/log_text"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:padding="8dp"
                android:text="" />
        </ScrollView>

        <Button
            android:id="@+id/clearLogBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/clear_log"
            android:backgroundTint="@color/button_secondary"
            android:textColor="@color/button_text" />
    </LinearLayout>
</LinearLayout>